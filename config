{
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "height": 42,
    "modules-left": [
        "custom/logo",
        "hyprland/workspaces",
        "mpris",
        "custom/cava"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "wireplumber",
        "network",
        "bluetooth",
        "cpu",
        "memory",
        "battery",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "default": "ΎΕΣ",
            "active": "ΎΗΤ",
            "urgent": "ΎΒς"
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{status_icon} <i>{title}</i>",
        "player-icons": {
            "default": "έΨ╢",
            "mpv": "ΎΞχ ",
            "spotify": "ΎΗ╝ ",
            "firefox": "ΎΚσ ",
            "chromium": "ΎΚρ ",
            "brave": "≤░Ψθ ",
            "vlc": "≤░Χ╝ ",
            "amberol": "≤░ΟΗ "
        },
        "status-icons": {
            "paused": "έΠ╕"
        },
        "max-length": 20
    },
    "custom/cava": {
        "exec": "/home/bimbok/.config/waybar/Scripts/cava.sh",
        "format": "{}",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": "≤░Ξδ {percentage}%",
        "states": {
            "warning": 70,
            "critical": 90
        },
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G ({percentage}%)"
    },
    "cpu": {
        "interval": 5,
        "format": "≤░╗ι {usage}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "Ός░ {:%a, %d %b %Y}",
        "format": "ΎΑΩ {:%I:%M %p}"
    },
    "bluetooth": {
        "format": "ΎΛΦ",
        "format-connected": "ΎΛΦ {num_connections}",
        "format-connected-battery": "ΎΛΦ {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "format-off": "≤░Γ▓",
        "format-disabled": "≤░Γ▓",
        "on-click": "/home/bimbok/.config/waybar/Scripts/bluetooth.sh &"
    },
    "network": {
        "format-wifi": "{icon}",
        "format-icons": ["≤░νψ ", "≤░νθ ", "≤░νλ ", "≤░νξ ", "≤░νρ "],
        "format-ethernet": "≤░ΑΓ ",
        "format-alt": "≤▒δΘ ",
        "format-disconnected": "≤░Ψς ",
        "format-disabled": "≤░Ψς ",
        "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
        "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "/home/bimbok/.config/waybar/Scripts/wifi.sh &",
        "on-click-right": "~/.config/rofi/wifi/wifinew.sh &",
        "interval": 5
    },
    "wireplumber": {
        "format": "{icon} {volume}%",
        "nospacing": 1,
        "tooltip-format": "Volume : {volume}%",
        "format-muted": "≤░ζθ ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "≤░Γ░",
            "headset": "≤░Γ░",
            "bluetooth": "≤░Γ░",
            "default": ["≤░ΨΑ ", "≤░Χ╛ ", "ΎΑρ "]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 1%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-",
        "scroll-step": 1
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["≤░Δη ", "≤░Δθ ", "≤░Δι "],
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "min-length": 6
    },
    "custom/logo": {
        "format": " ΎΝΔ ",
        "tooltip": false,
        "on-click": "/home/bimbok/.config/waybar/Scripts/theme-change.sh &",
        "on-click-right": "~/.config/waybar/Scripts/wallpaper_select.sh &"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": {
            "charging": ["≤░λε ","≤░ΓΗ ","≤░ΓΘ ","≤░ΓΙ ","≤░λζ ","≤░ΓΚ ","≤░λη ","≤░ΓΛ ","≤░ΓΜ ","≤░ΓΖ "],
            "default": ["≤░Β║","≤░Β╗","≤░Β╝","≤░Β╜","≤░Β╛","≤░Β┐","≤░ΓΑ","≤░ΓΒ","≤░ΓΓ","≤░Β╣"]
        },
        "format-full": "{icon} {capacity}%",
        "interval": 5,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "tooltip": true,
        "tooltip-format": "{timeTo} {capacity}%"
    },
    "custom/power": {
        "format": "≤░νΗ",
        "tooltip": false,
        "on-click": "wlogout"
    }
}
